@model ViewModel.Patient.DoctorsBySpecialtyVM

@{
    ViewData["Title"] = "Doctors";
    var patientEmail = ViewBag.PatientEmail as string;
}

<div class="mc-hero mb-4" data-aos="fade-in">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-3 text-white" style="width: 56px; height: 56px; background: linear-gradient(135deg, var(--mc-primary), var(--mc-accent)); font-size: 1.5rem;">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <h2 class="mb-1">@Model.SpecialtyName Specialists</h2>
                <p class="text-muted mb-0">Choose a top-rated doctor and check available times.</p>
            </div>
        </div>
        <a asp-action="Index" asp-route-patientEmail="@patientEmail" class="btn btn-light rounded-pill border px-4 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to Specialties
        </a>
    </div>
</div>

@if (!Model.Doctors.Any())
{
    <div class="alert alert-light text-center border p-5 mc-card" data-aos="fade-in">
        <i class="bi bi-person-x text-muted mb-3" style="font-size: 3rem;"></i>
        <h5>No Doctors Available</h5>
        <p class="text-muted mb-0">There are currently no specialists available in this department.</p>
    </div>
}
else
{
<div class="row g-4">
    @foreach (var (doctor, index) in Model.Doctors.Select((item, i) => (item, i)))
    {
        var delay = (index % 4) + 1;
        <div class="col-md-6" data-aos="fade-up" data-aos-delay="@(delay * 100)">
            <div class="mc-grid-card h-100 p-4 border-0 shadow-sm d-flex flex-column">
                <div class="d-flex align-items-center mb-3">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(doctor.FullName)&background=random&color=fff&size=64&rounded=true&font-size=0.33" alt="@doctor.FullName" class="rounded-circle shadow-sm me-3" width="64" height="64" />
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">@doctor.FullName</h5>
                        <span class="badge rounded-pill bg-light text-primary border mt-1">@Model.SpecialtyName</span>
                    </div>
                </div>
                
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <div class="border rounded-3 p-2 text-center bg-white">
                            <i class="bi bi-clock-history text-warning"></i>
                            <span class="fw-bold ms-1">@doctor.ExperienceYears Yrs</span>
                            <small class="text-muted d-block" style="font-size:0.7rem;">Experience</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border rounded-3 p-2 text-center bg-white">
                            <i class="bi bi-currency-dollar text-success"></i>
                            <span class="fw-bold ms-1">@doctor.HourRate</span>
                            <small class="text-muted d-block" style="font-size:0.7rem;">Per Hour</small>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(doctor.Bio))
                {
                    <div class="p-3 bg-light rounded-3 border mb-3 flex-grow-1">
                        <p class="small text-muted mb-0 fst-italic">"@doctor.Bio"</p>
                    </div>
                }

                <div class="mt-auto pt-2 border-top">
                    <a asp-action="Book" asp-route-doctorId="@doctor.Id" asp-route-patientEmail="@patientEmail" class="btn btn-primary w-100 rounded-pill fw-semibold shadow-sm">
                        <i class="bi bi-calendar2-check me-2"></i> Check Availability
                    </a>
                </div>
            </div>
        </div>
    }
</div>
}
