@model ViewModel.Patient.MyRecordsVM

@{
    ViewData["Title"] = "My Records";
    var patientEmail = ViewBag.PatientEmail as string;
}

<div class="mc-hero mb-4" data-aos="fade-in">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div class="d-flex align-items-center">
            <div class="rounded-circle d-flex align-items-center justify-content-center me-3 text-white" style="width: 56px; height: 56px; background: linear-gradient(135deg, #10b981, #059669); font-size: 1.5rem;">
                <i class="bi bi-journal-medical"></i>
            </div>
            <div>
                <h2 class="mb-1">My Records</h2>
                <p class="text-muted mb-0">Your health journey all in one place.</p>
            </div>
        </div>
        <a asp-action="Prescriptions" asp-route-patientEmail="@patientEmail" class="btn btn-primary rounded-pill shadow-sm px-4">
            <i class="bi bi-capsule me-2"></i> My Prescriptions
        </a>
    </div>
</div>

@if (!Model.Records.Any())
{
    <div class="alert alert-light text-center border p-5 mc-card" data-aos="fade-in">
        <i class="bi bi-journal-x text-muted mb-3" style="font-size: 3rem;"></i>
        <h5>No Records Found</h5>
        <p class="text-muted mb-0">You don't have any appointments or health records yet.</p>
    </div>
}
else
{
<!-- Status Filter Tabs -->
<div class="mb-4" data-aos="fade-up">
    <div class="d-flex flex-wrap align-items-center gap-3">
        <div class="btn-group shadow-sm bg-white rounded-pill p-1 border" role="group" id="statusFilter">
            <button type="button" class="btn btn-sm rounded-pill active" data-filter="All">All</button>
            <button type="button" class="btn btn-sm rounded-pill" data-filter="Pending"><i class="bi bi-hourglass-split text-warning"></i> Pending</button>
            <button type="button" class="btn btn-sm rounded-pill" data-filter="Confirmed"><i class="bi bi-check-circle text-primary"></i> Confirmed</button>
            <button type="button" class="btn btn-sm rounded-pill" data-filter="Completed"><i class="bi bi-check-all text-success"></i> Completed</button>
            <button type="button" class="btn btn-sm rounded-pill" data-filter="Cancelled"><i class="bi bi-x-circle text-danger"></i> Cancelled</button>
        </div>
        <span class="badge bg-light text-secondary border rounded-pill px-3 py-2" id="filterCount">Showing @Model.Records.Count records</span>
    </div>
</div>

<div class="row g-4" id="recordsList">
    @foreach (var (record, index) in Model.Records.Select((item, i) => (item, i)))
    {
        var delay = (index % 4) + 1;
        <div class="col-md-6 record-item" data-aos="fade-up" data-aos-delay="@(delay * 100)" data-status="@record.Status">
            <div class="mc-grid-card h-100 p-4 border-0 shadow-sm d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="d-flex align-items-center">
                        <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; font-size: 1.25rem;">
                            <i class="bi bi-person-fill text-secondary"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">@record.DoctorName</h5>
                            <span class="text-muted small">@record.SpecialtyName</span>
                        </div>
                    </div>
                    
                    <span class="badge rounded-pill @(record.Status == "Pending" ? "bg-warning bg-opacity-10 text-warning border border-warning" :
                                                       record.Status == "Confirmed" ? "bg-primary bg-opacity-10 text-primary border border-primary" :
                                                       record.Status == "Completed" ? "bg-success bg-opacity-10 text-success border border-success" :
                                                       record.Status == "Cancelled" ? "bg-danger bg-opacity-10 text-danger border border-danger" : "bg-secondary")">
                        @record.Status
                    </span>
                </div>

                <div class="mb-3 p-3 bg-light rounded-3 border">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-calendar-check text-primary me-2 fs-5"></i>
                        <div>
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size:0.65rem;">Appointment Date</small>
                            <span class="fw-semibold">@record.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")</span>
                        </div>
                    </div>
                </div>

                @if (record.Prescriptions != null && record.Prescriptions.Any())
                {
                    <div class="mt-auto mb-3">
                        <h6 class="fw-bold text-muted small text-uppercase mb-2"><i class="bi bi-capsule me-1"></i> Prescriptions</h6>
                        <div class="d-flex flex-column gap-2">
                            @foreach (var rx in record.Prescriptions)
                            {
                                <div class="p-2 border rounded-3 bg-white shadow-sm d-flex justify-content-between align-items-center">
                                    <span class="fw-semibold small text-dark"><i class="bi bi-dot text-primary"></i> @rx.MedicationName</span>
                                    <span class="badge bg-light text-secondary border">@rx.Dosage, @rx.Frequency</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (record.Status == "Confirmed" || record.Status == "Pending")
                {
                    <div class="mt-auto pt-3 border-top text-end">
                        <form asp-action="CancelAppointment" asp-route-patientEmail="@patientEmail" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="appointmentId" value="@record.AppointmentId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-semibold"
                                    onclick="return confirm('Are you sure you want to cancel this appointment? This cannot be undone.')">
                                <i class="bi bi-x-circle me-1"></i> Cancel Appt
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
</div>
}

@section Scripts {
<script>
    const filterBtns = document.querySelectorAll('#statusFilter button');
    const items = document.querySelectorAll('.record-item');
    const countEl = document.getElementById('filterCount');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const filter = btn.dataset.filter;
            let visible = 0;

            items.forEach(item => {
                if (filter === 'All' || item.dataset.status === filter) {
                    item.style.display = '';
                    visible++;
                } else {
                    item.style.display = 'none';
                }
            });

            if (countEl) {
                countEl.textContent = `Showing ${visible} record${visible !== 1 ? 's' : ''}`;
            }
        });
    });
</script>
}
