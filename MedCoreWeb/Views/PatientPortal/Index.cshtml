@model ViewModel.Patient.PatientPortalHomeVM

@{
    ViewData["Title"] = "Find Your Specialist";
    var patientEmail = ViewBag.PatientEmail as string;
}

<div class="mc-hero mb-4" data-aos="fade-in">
    <h2 class="mb-2">Find Your Specialist</h2>
    <p class="text-muted mb-0">We're here to help you feel your best. Browse top specialties and connect with expert doctors.</p>
</div>

<div class="row g-4">
    @foreach (var (specialty, index) in Model.Specialties.Select((item, i) => (item, i)))
    {
        var delay = (index % 4) + 1;
        var iconColors = new[] { "text-primary bg-primary bg-opacity-10", "text-success bg-success bg-opacity-10", "text-warning bg-warning bg-opacity-10", "text-info bg-info bg-opacity-10", "text-danger bg-danger bg-opacity-10" };
        var colorClass = iconColors[index % iconColors.Length];

        <div class="col-md-4" data-aos="fade-up" data-aos-delay="@(delay * 100)">
            <div class="mc-grid-card h-100 p-4 border-0 shadow-sm d-flex flex-column">
                <div class="d-flex align-items-center mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3 @colorClass" style="width: 48px; height: 48px; font-size: 1.25rem;">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">@specialty.Name</h5>
                        <span class="badge rounded-pill bg-light text-dark border mt-1">@specialty.DoctorsCount doctors</span>
                    </div>
                </div>
                
                <p class="text-muted small flex-grow-1">@specialty.Description</p>
                
                <div class="mt-3 pt-3 border-top">
                    <a asp-action="Doctors" asp-route-specialtyId="@specialty.Id" asp-route-patientEmail="@patientEmail" class="btn btn-outline-primary w-100 rounded-pill fw-semibold">
                        View Specialists <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    }
</div>
