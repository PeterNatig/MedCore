@model ViewModel.Patient.BookAppointmentVM

@{
    ViewData["Title"] = "Pick a Time";
    var patientEmail = ViewBag.PatientEmail as string;
    var availableCount = Model.AvailableSlots.Count(s => !s.IsBooked);
    var slotsByDate = Model.AvailableSlots
        .GroupBy(s => s.StartTime.Date)
        .OrderBy(g => g.Key);
}

<div class="mc-hero mb-4" data-aos="fade-in">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center">
            <a asp-action="Doctors" asp-route-patientEmail="@patientEmail" class="text-decoration-none text-muted me-3 fs-4">
                <i class="bi bi-arrow-left-circle"></i>
            </a>
            <div>
                <h2 class="mb-1 fw-bold">Pick a Time</h2>
                <p class="text-muted mb-0">Choose a slot that works for you</p>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.DoctorName)&background=random&color=fff&size=40&rounded=true&font-size=0.33" 
                 alt="@Model.DoctorName" class="rounded-circle shadow-sm" width="40" height="40" />
            <div>
                <span class="fw-bold d-block lh-1">@Model.DoctorName</span>
                <small class="text-muted">@Model.SpecialtyName</small>
            </div>
        </div>
    </div>
</div>

@if (!Model.AvailableSlots.Any())
{
    <div class="mc-card text-center p-5 border" data-aos="fade-in">
        <i class="bi bi-calendar-x text-muted d-block mb-3" style="font-size: 3rem;"></i>
        <h5 class="fw-bold">No Slots Available</h5>
        <p class="text-muted mb-0">This doctor has no upcoming schedule slots at the moment.</p>
    </div>
}
else
{
    <!-- Info Banner -->
    <div class="p-3 rounded-3 border mb-4 d-flex align-items-center" data-aos="fade-up"
         style="background: linear-gradient(135deg, #ecfdf5, #f0fdf4); border-color: #a7f3d0 !important;">
        <i class="bi bi-info-circle-fill text-success me-2 fs-5"></i>
        <span>
            <strong>@availableCount slot@(availableCount != 1 ? "s" : "") available.</strong>
            <span class="text-muted">Tap any green slot to book instantly.</span>
        </span>
    </div>

    <!-- Legend -->
    <div class="d-flex align-items-center gap-4 mb-4" data-aos="fade-up" data-aos-delay="50">
        <div class="d-flex align-items-center gap-2">
            <span class="d-inline-block rounded-circle" style="width: 12px; height: 12px; background: #10b981;"></span>
            <small class="text-muted fw-semibold">Available</small>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="d-inline-block rounded-circle" style="width: 12px; height: 12px; background: #d1d5db;"></span>
            <small class="text-muted fw-semibold">Booked</small>
        </div>
    </div>

    <form asp-action="Book" asp-route-patientEmail="@patientEmail" method="post">
        <input asp-for="DoctorId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        @foreach (var dateGroup in slotsByDate)
        {
            var isToday = dateGroup.Key.Date == DateTime.UtcNow.Date;
            var isTomorrow = dateGroup.Key.Date == DateTime.UtcNow.Date.AddDays(1);
            var dateLabel = isToday ? "Today's Schedule" : isTomorrow ? "Tomorrow's Schedule" : dateGroup.Key.ToString("dddd, dd MMM yyyy");

            <div class="mc-grid-card p-4 mb-4 border-0 shadow-sm" data-aos="fade-up" data-aos-delay="100">
                <h6 class="fw-bold mb-3 d-flex align-items-center">
                    <i class="bi bi-calendar3 text-primary me-2"></i> @dateLabel
                </h6>
                <div class="row g-3">
                    @foreach (var slot in dateGroup.OrderBy(s => s.StartTime))
                    {
                        if (slot.IsBooked)
                        {
                            <div class="col-6 col-md-3">
                                <div class="slot-chip slot-booked">
                                    <i class="bi bi-clock"></i> @slot.StartTime.ToString("hh:mm tt")
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="col-6 col-md-3">
                                <label class="slot-chip slot-available">
                                    <input type="radio" name="SelectedScheduleId" value="@slot.ScheduleId" class="d-none slot-radio" />
                                    <i class="bi bi-clock"></i> @slot.StartTime.ToString("hh:mm tt")
                                </label>
                            </div>
                        }
                    }
                </div>
            </div>
        }

        <!-- Sticky confirm bar -->
        <div class="mc-grid-card p-3 border-0 shadow-sm d-flex align-items-center justify-content-between" id="bookingBar" 
             style="display: none !important;" data-aos="fade-up">
            <div>
                <i class="bi bi-check-circle-fill text-success me-2 fs-5"></i>
                <span class="fw-semibold" id="selectedSlotLabel">Select a time slot above</span>
            </div>
            <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm fw-semibold" id="confirmBtn" disabled>
                <i class="bi bi-calendar-check me-2"></i> Confirm Booking
            </button>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const radios = document.querySelectorAll('.slot-radio');
            const bar = document.getElementById('bookingBar');
            const label = document.getElementById('selectedSlotLabel');
            const btn = document.getElementById('confirmBtn');

            if (!radios.length) return;

            // Show bar immediately
            if (bar) bar.style.setProperty('display', 'flex', 'important');

            radios.forEach(radio => {
                radio.addEventListener('change', function () {
                    // Remove active class from all
                    document.querySelectorAll('.slot-available').forEach(el => el.classList.remove('slot-selected'));
                    // Add to selected
                    this.closest('.slot-available').classList.add('slot-selected');
                    // Update bar
                    const timeText = this.closest('.slot-available').textContent.trim();
                    if (label) label.textContent = 'Selected: ' + timeText;
                    if (btn) btn.disabled = false;
                });
            });
        });
    </script>
}
