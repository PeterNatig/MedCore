@model ViewModel.Patient.PatientPrescriptionsVM

@{
    ViewData["Title"] = "My Prescriptions";
}

<div class="mc-hero mb-4" data-aos="fade-in">
    <div class="d-flex align-items-center">
        <div class="rounded-circle d-flex align-items-center justify-content-center me-3 text-white" style="width: 56px; height: 56px; background: linear-gradient(135deg, var(--mc-primary), var(--mc-accent)); font-size: 1.5rem;">
            <i class="bi bi-capsule"></i>
        </div>
        <div>
            <h2 class="mb-1">My Prescriptions</h2>
            <p class="text-muted mb-0">All medications prescribed to you by your doctors.</p>
        </div>
    </div>
</div>

@if (!Model.Prescriptions.Any())
{
    <div class="alert alert-light text-center border p-5 mc-card" data-aos="fade-in">
        <i class="bi bi-prescription text-muted mb-3" style="font-size: 3rem;"></i>
        <h5>No Prescriptions Found</h5>
        <p class="text-muted mb-0">You don't have any prescriptions on record yet.</p>
    </div>
}
else
{
<div class="row g-4">
    @foreach (var (rx, index) in Model.Prescriptions.Select((item, i) => (item, i)))
    {
        var delay = (index % 4) + 1;
        <div class="col-md-6" data-aos="fade-up" data-aos-delay="@(delay * 100)">
            <div class="mc-grid-card p-4 border-0 shadow-sm h-100 d-flex flex-column" style="background: linear-gradient(to right, #ffffff, #f8fafc);">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="d-flex">
                        <div class="rounded-3 d-flex align-items-center justify-content-center me-3 text-primary bg-primary bg-opacity-10" style="width: 48px; height: 48px; font-size: 1.25rem;">
                            <i class="bi bi-capsule-pill"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0 text-dark">@rx.MedicationName</h5>
                            @if (!string.IsNullOrWhiteSpace(rx.GenericName))
                            {
                                <span class="badge rounded-pill bg-light text-secondary border mt-1">@rx.GenericName</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="row g-2 mb-4">
                    <div class="col-6">
                        <div class="border rounded-3 p-3 text-center bg-white shadow-sm h-100">
                            <i class="bi bi-droplet-fill text-info mb-1 d-block" style="font-size: 1.2rem;"></i>
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Dosage</small>
                            <div class="fw-bolder text-dark">@rx.Dosage</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border rounded-3 p-3 text-center bg-white shadow-sm h-100">
                            <i class="bi bi-clock-fill text-warning mb-1 d-block" style="font-size: 1.2rem;"></i>
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Frequency</small>
                            <div class="fw-bolder text-dark">@rx.Frequency</div>
                        </div>
                    </div>
                </div>

                <div class="mt-auto p-3 rounded bg-white border">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-person-badge text-primary me-2"></i>
                        <span class="text-dark fw-semibold">Dr. @rx.DoctorName</span>
                        <span class="text-muted ms-auto small">@rx.SpecialtyName</span>
                    </div>
                    <div class="d-flex align-items-center mb-1">
                        <i class="bi bi-calendar-event text-muted me-2"></i>
                        <small class="text-muted">Appt: @rx.AppointmentDate.ToString("dd MMM yyyy, hh:mm tt")</small>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-pencil-square text-muted me-2"></i>
                        <small class="text-muted">Issued: @rx.PrescribedDate.ToString("dd MMM yyyy")</small>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
}
