@{
    ViewData["Title"] = "Create Accounts";
    ViewData["AdminTitle"] = "Create Accounts";
    ViewData["AdminSubtitle"] = "Register new doctor and patient users.";
    ViewData["AdminBreadcrumb"] = "Admin / Create Accounts";
}

<div class="row g-3">
    <div class="col-md-6">
        <div class="mc-card p-4 h-100">
            <h5>Create Doctor Account</h5>
            <p class="text-muted">Register a new doctor profile, license info, and credentials.</p>
            <a asp-controller="Account" asp-action="DoctorRegister" class="btn btn-primary">Open Doctor Registration</a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="mc-card p-4 h-100">
            <h5>Create Patient Account</h5>
            <p class="text-muted">Register a new patient account with medical profile details.</p>
            <a asp-controller="Account" asp-action="PatientRegister" class="btn btn-primary">Open Patient Registration</a>
        </div>
    </div>
</div>
