@model ViewModel.DoctorRegisterVM

@{
    ViewData["Title"] = "Doctor Registration";
    var specialties = ViewBag.Specialties as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<div class="mc-auth-wrap py-4">
    <div class="mc-auth-card" style="max-width:840px;" data-aos="fade-up">
        <div class="text-center mb-4">
            <h2 class="fw-bolder mb-1">Join <span style="color: var(--mc-primary);">MedCore</span></h2>
            <p class="text-muted">Create your doctor account and manage schedules and consultations.</p>
        </div>

        <div class="mc-segment mb-4">
            <a asp-action="PatientRegister">
                <i class="bi bi-person me-1"></i> Patient
            </a>
            <a class="active" asp-action="DoctorRegister">
                <i class="bi bi-heart-pulse me-1"></i> Doctor
            </a>
        </div>

        <form asp-action="DoctorRegister" method="post" data-aos="fade-in" data-aos-delay="100">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 p-2 rounded"></div>
            
            <h5 class="mb-3 border-bottom pb-2 text-muted"><i class="bi bi-person-badge me-2"></i>Personal Details</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="NationalID" class="form-control" placeholder="ID" />
                        <label asp-for="NationalID">National ID</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="FullName" class="form-control" placeholder="Name" />
                        <label asp-for="FullName">Full Name</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="UserName" class="form-control" placeholder="Username" />
                        <label asp-for="UserName">Username</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                        <label asp-for="Email">Email Address</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-floating">
                        <input asp-for="BirthDate" class="form-control" placeholder="DOB" type="date" />
                        <label asp-for="BirthDate">Date of Birth</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-floating">
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select gender</option>
                            <option value="@MedCore.Model.Enums.Gender.Male">Male</option>
                            <option value="@MedCore.Model.Enums.Gender.Female">Female</option>
                        </select>
                        <label asp-for="Gender">Gender</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-floating">
                        <select asp-for="SpecialtyId" class="form-select" asp-items="@specialties">
                            <option value="">Select specialty</option>
                        </select>
                        <label asp-for="SpecialtyId">Specialty</label>
                    </div>
                </div>
            </div>

            <div class="mc-card p-4 mb-4 border-primary border-opacity-25" style="background: var(--mc-primary-light);">
                <h5 class="mb-3 text-primary"><i class="bi bi-briefcase me-2"></i>Professional Details</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="LicenseNumber" class="form-control" placeholder="License" />
                            <label asp-for="LicenseNumber">License Number</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <input asp-for="ExperienceYears" class="form-control" placeholder="Years" />
                            <label asp-for="ExperienceYears">Experience (Years)</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <input asp-for="HourRate" class="form-control" placeholder="Rate" />
                            <label asp-for="HourRate">Hourly Rate ($)</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="form-floating">
                            <textarea asp-for="Bio" class="form-control" placeholder="Bio" style="height: 100px"></textarea>
                            <label asp-for="Bio">Professional Bio</label>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="mb-3 border-bottom pb-2 text-muted"><i class="bi bi-shield-lock me-2"></i>Security</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="Password" class="form-control" placeholder="Password" />
                        <label asp-for="Password">Password</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-floating">
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm" />
                        <label asp-for="ConfirmPassword">Confirm Password</label>
                    </div>
                </div>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm">
                    <i class="bi bi-person-check-fill me-2"></i> Register as Doctor
                </button>
            </div>
        </form>

        <p class="text-center mt-4 mb-0" data-aos="fade-in" data-aos-delay="200">
            Already have an account?
            <a asp-action="Login" asp-route-role="doctor" class="text-decoration-none fw-bold ms-1">Sign In</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
