@model ViewModel.LoginVM

@{
    ViewData["Title"] = "Login";
    var role = (ViewData["LoginRole"]?.ToString() ?? Context.Request.Query["role"].ToString());
    if (string.IsNullOrWhiteSpace(role))
    {
        role = "patient";
    }
    var patientActive = role.ToLower() == "patient";
    var doctorActive = !patientActive;
}

<div class="mc-auth-wrap">
    <div class="mc-auth-card" data-aos="zoom-in">
        <div class="text-center mb-4">
            <div class="mc-auth-icon" data-aos="flip-up" data-aos-delay="100">
                <i class="bi bi-shield-lock"></i>
            </div>
            <h2 class="fw-bold mb-1">Secure Entry</h2>
            <p class="text-muted mb-0">Sign in to MedCore Smart Hospital</p>
        </div>

        <div class="mc-segment mb-4" data-aos="fade-up" data-aos-delay="100">
            <a class="@(patientActive ? "active" : "")" asp-action="Login" asp-route-role="patient">
                <i class="bi bi-person me-1"></i> Patient
            </a>
            <a class="@(doctorActive ? "active" : "")" asp-action="Login" asp-route-role="doctor">
                <i class="bi bi-heart-pulse me-1"></i> Doctor
            </a>
        </div>

        <h5 class="mb-3 text-center" data-aos="fade-up" data-aos-delay="100">Sign in as @(patientActive ? "Patient" : "Doctor")</h5>
        
        <form asp-action="Login" asp-route-role="@role" method="post" data-aos="fade-up" data-aos-delay="100">
            <input type="hidden" name="role" value="@role" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 p-2 rounded"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <label asp-for="Email"><i class="bi bi-envelope me-1"></i> Email address</label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Password" />
                <label asp-for="Password"><i class="bi bi-key me-1"></i> Password</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            
            <div class="form-check mb-4">
                <input class="form-check-input" asp-for="RememberMe" />
                <label class="form-check-label text-muted" asp-for="RememberMe">Keep me signed in</label>
            </div>
            
            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm mb-3">
                <i class="bi bi-box-arrow-in-right me-2"></i> Sign In
            </button>
        </form>

        <div class="text-center mt-3 pt-3 border-top" data-aos="fade-in" data-aos-delay="200">
            <span class="text-muted">Don't have an account?</span>
            @if (doctorActive)
            {
                <a asp-action="DoctorRegister" class="text-decoration-none fw-bold ms-1">Register as Doctor</a>
            }
            else
            {
                <a asp-action="PatientRegister" class="text-decoration-none fw-bold ms-1">Register as Patient</a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
