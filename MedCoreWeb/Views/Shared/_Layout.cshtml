<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedCoreWeb</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MedCoreWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/aos.css" />
</head>
<body>
    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
        var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
        var isAuthPage = controller == "Account" && (action.Contains("Login") || action.Contains("Register"));
        var isAdminShell = User.Identity?.IsAuthenticated == true && User.IsInRole("Admin");
        var isDoctorShell = User.Identity?.IsAuthenticated == true && User.IsInRole("Doctor");
        var adminTitle = ViewData["AdminTitle"]?.ToString() ?? "Admin";
        var adminSubtitle = ViewData["AdminSubtitle"]?.ToString() ?? "Control all system modules";
        var adminBreadcrumb = ViewData["AdminBreadcrumb"]?.ToString() ?? $"Admin / {adminTitle}";
    }
    @if (isAdminShell)
    {
        <div class="mc-doctor-shell">
            <aside class="mc-sidebar">
                <div class="mc-sidebar-brand">MedCore <span>Admin Control</span></div>
                <nav class="mc-sidebar-nav">
                    <a class="@(action == "Index" && controller == "AdminPortal" ? "active" : "")" asp-controller="AdminPortal" asp-action="Index">Admin Dashboard</a>
                    <a class="@(action == "Specialties" ? "active" : "")" asp-controller="AdminPortal" asp-action="Specialties">Specialties</a>
                    <a class="@(action == "Medications" ? "active" : "")" asp-controller="AdminPortal" asp-action="Medications">Medications</a>
                    <a class="@(action == "Accounts" ? "active" : "")" asp-controller="AdminPortal" asp-action="Accounts">Create Accounts</a>
                    <a class="@(action == "OperateDoctor" ? "active" : "")" asp-controller="AdminPortal" asp-action="OperateDoctor">Operate Doctor</a>
                    <a class="@(action == "OperatePatient" ? "active" : "")" asp-controller="AdminPortal" asp-action="OperatePatient">Operate Patient</a>
                </nav>
            </aside>
            <div class="mc-doctor-content">
                <header class="mc-topbar">
                    <div class="container-fluid d-flex justify-content-end align-items-center py-2">
                        <span class="me-3 text-muted">@User.Identity?.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                        </form>
                    </div>
                </header>
                <main class="mc-main px-3 px-md-4">
                    <div class="mc-page-head mb-3">
                        <div class="mc-breadcrumb">@adminBreadcrumb</div>
                        <h2 class="mb-1">@adminTitle</h2>
                        <p class="text-muted mb-0">@adminSubtitle</p>
                    </div>
                    @if (TempData["FlowMessage"] is string adminMsg)
                    {
                        <div class="alert alert-info">@adminMsg</div>
                    }
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else if (isDoctorShell)
    {
        <div class="mc-doctor-shell">
            <aside class="mc-sidebar">
                <div class="mc-sidebar-brand">MedCore <span>Doctor Panel</span></div>
                <nav class="mc-sidebar-nav">
                    <a class="@(action == "Index" ? "active" : "")" asp-controller="DoctorPortal" asp-action="Index">Dashboard</a>
                    <a class="@(action == "Schedules" ? "active" : "")" asp-controller="DoctorPortal" asp-action="Schedules">Manage Schedules</a>
                    <a class="@(action == "Patients" ? "active" : "")" asp-controller="DoctorPortal" asp-action="Patients">Patient Records</a>
                    <a class="@(action == "ConsultationRoom" ? "active" : "")" asp-controller="DoctorPortal" asp-action="ConsultationRoom">Consultation Room</a>
                    <a class="@(action == "Chat" ? "active" : "")" asp-controller="DoctorPortal" asp-action="Chat"><i class="bi bi-robot text-primary me-2"></i> AI Assistant</a>
                </nav>
            </aside>
            <div class="mc-doctor-content">
                <header class="mc-topbar">
                    <div class="container-fluid d-flex justify-content-end align-items-center py-2">
                        <span class="me-3 text-muted">@User.Identity?.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                        </form>
                    </div>
                </header>
                <main class="mc-main px-3 px-md-4">
                    @if (TempData["FlowMessage"] is string doctorMsg)
                    {
                        <div class="alert alert-info">@doctorMsg</div>
                    }
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else if (isAuthPage)
    {
        <main class="mc-auth-main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="mc-shell">
            <header class="mc-topbar">
                <nav class="navbar navbar-expand-sm navbar-light">
                    <div class="container">
                        <a class="navbar-brand mc-brand" asp-area="" asp-controller="Home" asp-action="Index">MedCore <small>Patient Portal</small></a>
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-expanded="false">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                            <ul class="navbar-nav flex-grow-1 gap-1">
                                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Patient"))
                                {
                                    <li class="nav-item"><a class="nav-link" asp-controller="PatientPortal" asp-action="Index">Find a Doctor</a></li>
                                    <li class="nav-item"><a class="nav-link" asp-controller="PatientPortal" asp-action="MyRecords">My Records</a></li>
                                    <li class="nav-item"><a class="nav-link" asp-controller="PatientPortal" asp-action="Prescriptions">Prescriptions</a></li>
                                    <li class="nav-item"><a class="nav-link text-primary fw-bold" asp-controller="PatientPortal" asp-action="Chat"><i class="bi bi-stars"></i> AI Assistant</a></li>
                                }
                                else if (User.Identity?.IsAuthenticated != true)
                                {
                                    <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Login</a></li>
                                }
                            </ul>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                                </form>
                            }
                        </div>
                    </div>
                </nav>
            </header>
            <main class="mc-main">
                <div class="container">
                    @if (TempData["FlowMessage"] is string userMsg)
                    {
                        <div class="alert alert-info">@userMsg</div>
                    }
                    @RenderBody()
                </div>
            </main>
        </div>
    }
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/aos.js"></script>
    <script>AOS.init({ once: true, duration: 800, offset: 50 });</script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
